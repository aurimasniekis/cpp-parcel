#pragma once

/**
 * @file version.h
 * @brief parcel version macros — numeric components and the dotted string.
 *
 * Generated by the build system from `version.h.in`; the values are taken from
 * the CMake/Meson project version (the single source of truth). From C++,
 * prefer the `parcel::version*` constants in `<parcel/parcel.h>` — these macros
 * exist for preprocessor-time checks.
 */

// NOLINTBEGIN(cppcoreguidelines-macro-to-enum,modernize-macro-to-enum)
#define PARCEL_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define PARCEL_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define PARCEL_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define PARCEL_VERSION_STRING "@PROJECT_VERSION@"
// NOLINTEND(cppcoreguidelines-macro-to-enum,modernize-macro-to-enum)
